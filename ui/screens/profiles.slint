import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export struct ProfileUiItem {
    id: int,
    name: string,
    protocol: string,
    address: string,
    port: int,
    delay: string,
    is_active: bool,
}

export component ProfilesScreen inherits Rectangle {
    in property <[ProfileUiItem]> profiles: [];
    in-out property <string> new-sub-url: "";
    in-out property <string> new-sub-name: "";
    
    callback select-profile(int);
    callback delete-profile(int);
    callback ping-profile(int);
    callback import-subscription(string, string); // name, url
    callback import-clipboard();
    callback show-sub-menu(int, string, string); // id, name, url

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;

        // Header Title
        Text {
            text: "Subscriptions";
            color: Theme.text-primary;
            font-size: Theme.font-header;
            font-weight: 800;
        }

        // Import compact section
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.card-radius;
            
            VerticalLayout {
                padding: Theme.card-padding;
                spacing: Theme.gap-md;
                
                Text {
                    text: "Import Subscription Link";
                    color: Theme.text-primary;
                    font-size: Theme.font-primary;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: Theme.gap-md;
                    
                    // Name Input
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Name"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                        TextInput := TextInput {
                            text: root.new-sub-name;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            single-line: true;
                            edited => { root.new-sub-name = self.text; }
                        }
                        Rectangle { height: 1px; background: Theme.elevated; }
                    }

                    // URL Input
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "URL"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                        UrlInput := TextInput {
                            text: root.new-sub-url;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            single-line: true;
                            edited => { root.new-sub-url = self.text; }
                        }
                        Rectangle { height: 1px; background: Theme.elevated; }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.gap-lg;
                    alignment: end;
                    
                    IconButton {
                        icon-source: Icons.clipboard;
                        text: "Paste";
                        background-color: Theme.elevated;
                        hover-background-color: Theme.elevated.brighter(10%);
                        active-background-color: Theme.surface;
                        width: 70px;
                        height: 24px;
                        clicked => { root.import-clipboard(); }
                    }

                    IconButton {
                        icon-source: Icons.fetch;
                        text: "Fetch";
                        background-color: Theme.accent;
                        hover-background-color: Theme.accent.brighter(10%);
                        active-background-color: Theme.accent.darker(15%);
                        width: 70px;
                        height: 24px;
                        clicked => { 
                            root.import-subscription(root.new-sub-name, root.new-sub-url);
                            root.new-sub-name = "";
                            root.new-sub-url = "";
                        }
                    }
                }
            }
        }

        // Scrollable List of Subscriptions (profiles representation)
        Flickable {
            viewport-height: profiles.length * 44px;
            
            VerticalLayout {
                spacing: 4px;
                alignment: start;
                
                for profile[idx] in profiles : Rectangle {
                    height: 40px;
                    background: profile.is-active ? Theme.elevated : Theme.surface;
                    border-radius: Theme.card-radius;
                    border-color: profile.is-active ? Theme.accent : transparent;
                    border-width: 1px;
                    
                    HorizontalLayout {
                        padding-left: Theme.card-padding;
                        padding-right: Theme.card-padding;
                        alignment: space-between;
                        
                        // Left: active indicator, name, and timestamp
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: profile.is-active ? Theme.success : Theme.text-muted;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                
                                Text {
                                    text: profile.name;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-primary;
                                    font-weight: 600;
                                    overflow: elide;
                                }
                                
                                Text {
                                    text: "Updated: " + profile.delay;
                                    color: Theme.text-muted;
                                    font-size: Theme.font-metadata;
                                }
                            }
                        }

                        // Right: Vertical Ellipsis Options menu trigger
                        VerticalLayout {
                            alignment: center;
                            
                            Rectangle {
                                width: 24px;
                                height: 24px;
                                border-radius: 12px;
                                background: transparent;
                                
                                TouchArea {
                                    clicked => { root.show-sub-menu(profile.id, profile.name, profile.address); }
                                    
                                    Text {
                                        text: "⋮";
                                        color: Theme.text-primary;
                                        font-size: 16px;
                                        font-weight: 800;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
