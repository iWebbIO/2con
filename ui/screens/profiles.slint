import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export struct ProfileUiItem {
    id: int,
    name: string,
    protocol: string,
    address: string,
    port: int,
    delay: string,
    is_active: bool,
}

export component ProfilesScreen inherits Rectangle {
    in property <[ProfileUiItem]> profiles: [];
    in-out property <string> new-sub-url: "";
    in-out property <string> new-sub-name: "";
    
    callback select-profile(int);
    callback delete-profile(int);
    callback ping-profile(int);
    callback import-subscription(string, string); // name, url
    callback import-clipboard();

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;

        // Header and import section
        Text {
            text: "Profile Configuration Manager";
            color: Theme.text-primary;
            font-size: 20px;
            font-weight: 700;
        }

        // Import actions
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.card-radius;
            
            VerticalLayout {
                padding: Theme.card-padding;
                spacing: 12px;
                
                Text {
                    text: "Import Profiles / Subscription Link";
                    color: Theme.text-primary;
                    font-size: 14px;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: 8px;
                    
                    // Subscription Name Input
                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "Name"; color: Theme.text-secondary; font-size: 10px; }
                        TextInput := TextInput {
                            text: root.new-sub-name;
                            color: Theme.text-primary;
                            font-size: 13px;
                            single-line: true;
                            edited => { root.new-sub-name = self.text; }
                        }
                        Rectangle { height: 1px; background: Theme.elevated; }
                    }

                    // Subscription URL Input
                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "URL / Link"; color: Theme.text-secondary; font-size: 10px; }
                        UrlInput := TextInput {
                            text: root.new-sub-url;
                            color: Theme.text-primary;
                            font-size: 13px;
                            single-line: true;
                            edited => { root.new-sub-url = self.text; }
                        }
                        Rectangle { height: 1px; background: Theme.elevated; }
                    }
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: end;
                    
                    // Import Clipboard Button
                    IconButton {
                        icon-source: Icons.clipboard;
                        text: "Import Clipboard";
                        background-color: Theme.elevated;
                        hover-background-color: Theme.elevated.brighter(10%);
                        active-background-color: Theme.surface;
                        width: 160px;
                        height: 32px;
                        clicked => { root.import-clipboard(); }
                    }

                    // Download Sub Button
                    IconButton {
                        icon-source: Icons.fetch;
                        text: "Fetch Sub";
                        background-color: Theme.accent;
                        hover-background-color: Theme.accent.brighter(10%);
                        active-background-color: Theme.accent.darker(15%);
                        width: 120px;
                        height: 32px;
                        clicked => { 
                            root.import-subscription(root.new-sub-name, root.new-sub-url);
                            root.new-sub-name = "";
                            root.new-sub-url = "";
                        }
                    }
                }
            }
        }

        // Profile lists
        Text {
            text: "Available Servers";
            color: Theme.text-primary;
            font-size: 16px;
            font-weight: 600;
        }

        // Scrollable List of Profiles
        Flickable {
            viewport-height: profiles.length * 70px;
            
            VerticalLayout {
                spacing: 8px;
                
                for profile[idx] in profiles : Rectangle {
                    height: 60px;
                    background: profile.is-active ? Theme.elevated : Theme.surface;
                    border-radius: Theme.card-radius;
                    border-color: profile.is-active ? Theme.accent : transparent;
                    border-width: 1px;
                    
                    HorizontalLayout {
                        padding-left: Theme.card-padding;
                        padding-right: Theme.card-padding;
                        spacing: 12px;
                        alignment: space-between;
                        
                        // Main Click Area (Select node)
                        TouchArea {
                            clicked => { root.select-profile(profile.id); }
                            
                            HorizontalLayout {
                                spacing: 12px;
                                alignment: start;
                                
                                // Protocol Badge
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 64px;
                                        height: 24px;
                                        background: Theme.elevated;
                                        border-radius: 4px;
                                        
                                        Text {
                                            text: profile.protocol;
                                            color: Theme.text-primary;
                                            font-size: 11px;
                                            font-weight: 700;
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    
                                    Text {
                                        text: profile.name;
                                        color: Theme.text-primary;
                                        font-size: 14px;
                                        font-weight: 600;
                                    }
                                    
                                    Text {
                                        text: profile.address + ":" + profile.port;
                                        color: Theme.text-secondary;
                                        font-size: 11px;
                                    }
                                }
                            }
                        }

                        // Right actions (Delay, Ping, Delete)
                        HorizontalLayout {
                            spacing: 12px;
                            alignment: end;
                            
                            VerticalLayout {
                                alignment: center;
                                HorizontalLayout {
                                    spacing: 12px;
                                    alignment: end;
                                    
                                    // Delay Text
                                    Text {
                                        text: profile.delay == "" ? "N/A" : profile.delay;
                                        color: profile.delay == "Timeout" ? Theme.danger : Theme.success;
                                        font-size: 12px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }

                                    // Ping Trigger
                                    IconButton {
                                        icon-source: Icons.nav-proxies;
                                        icon-size: 12px;
                                        background-color: Theme.elevated;
                                        hover-background-color: Theme.elevated.brighter(10%);
                                        active-background-color: Theme.surface;
                                        width: 44px;
                                        height: 30px;
                                        clicked => { root.ping-profile(profile.id); }
                                    }

                                    // Delete Trigger
                                    IconButton {
                                        icon-source: Icons.delete;
                                        icon-size: 12px;
                                        background-color: Theme.danger;
                                        hover-background-color: Theme.danger.brighter(10%);
                                        active-background-color: Theme.danger.darker(15%);
                                        width: 44px;
                                        height: 30px;
                                        clicked => { root.delete-profile(profile.id); }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
