import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export struct ProfileUiItem {
    id: int,
    name: string,
    protocol: string,   // "Subscription" or "LocalGroup" — acts as the type discriminator
    address: string,
    port: int,
    delay: string,
    is_active: bool,
}

export component ProfilesScreen inherits Rectangle {
    in property <[ProfileUiItem]> profiles: [];
    in-out property <string> new-sub-url: "";
    in-out property <string> new-sub-name: "";
    in-out property <string> new-group-name: "";
    
    callback select-profile(int);
    callback delete-profile(int);
    callback ping-profile(int);
    callback import-subscription(string, string); // name, url
    callback import-clipboard();
    callback create-local-group(string);          // group name
    callback rename-profile(int, string);         // id, new name
    callback add-config-to-group(int);            // sub_id
    callback show-sub-menu(int, string, string, string); // id, name, url, type ("Subscription"|"LocalGroup")

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;

        // Header Title
        Text {
            text: "Profiles";
            color: Theme.text-primary;
            font-size: Theme.font-header;
            font-weight: 800;
        }

        // Import Subscription compact section
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.card-radius;
            border-width: 1px;
            border-color: Theme.border;
            
            VerticalLayout {
                padding: Theme.card-padding;
                spacing: Theme.gap-md;
                
                Text {
                    text: "Import Subscription Link";
                    color: Theme.text-primary;
                    font-size: Theme.font-primary;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: Theme.gap-md;
                    
                    // Name Input
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Name"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                        TextInput := TextInput {
                            text: root.new-sub-name;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            single-line: true;
                            edited => { root.new-sub-name = self.text; }
                        }
                        Rectangle { height: 1px; background: Theme.border; }
                    }

                    // URL Input
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "URL"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                        UrlInput := TextInput {
                            text: root.new-sub-url;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            single-line: true;
                            edited => { root.new-sub-url = self.text; }
                        }
                        Rectangle { height: 1px; background: Theme.border; }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.gap-lg;
                    alignment: end;
                    
                    IconButton {
                        icon-source: Icons.clipboard;
                        text: "Paste";
                        background-color: Theme.elevated;
                        hover-background-color: Theme.elevated.brighter(10%);
                        active-background-color: Theme.surface;
                        width: 70px;
                        height: 24px;
                        clicked => { root.import-clipboard(); }
                    }

                    IconButton {
                        icon-source: Icons.fetch;
                        text: "Fetch";
                        background-color: Theme.accent-cyan;
                        hover-background-color: Theme.accent-cyan.brighter(10%);
                        active-background-color: Theme.accent-cyan.darker(15%);
                        width: 70px;
                        height: 24px;
                        clicked => { 
                            root.import-subscription(root.new-sub-name, root.new-sub-url);
                            root.new-sub-name = "";
                            root.new-sub-url = "";
                        }
                    }
                }
            }
        }

        // Create Local Group compact section
        Rectangle {
            background: Theme.accent-purple.with-alpha(0.1);
            border-radius: Theme.card-radius;
            border-width: 1px;
            border-color: Theme.accent-purple.with-alpha(0.3);
            height: 36px;

            HorizontalLayout {
                padding-left: Theme.card-padding;
                padding-right: Theme.card-padding;
                alignment: space-between;

                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    Text { text: "New Local Group"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                    GroupNameInput := TextInput {
                        text: root.new-group-name;
                        color: Theme.text-primary;
                        font-size: Theme.font-primary;
                        single-line: true;
                        edited => { root.new-group-name = self.text; }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    IconButton {
                        text: "+ Create";
                        background-color: Theme.accent-purple.with-alpha(0.4);
                        hover-background-color: Theme.accent-purple.with-alpha(0.6);
                        active-background-color: Theme.accent-purple.with-alpha(0.2);
                        width: 60px;
                        height: 22px;
                        clicked => {
                            root.create-local-group(root.new-group-name);
                            root.new-group-name = "";
                        }
                    }
                }
            }
        }

        // Scrollable List of profiles/subscriptions
        Flickable {
            viewport-height: profiles.length * 46px;
            
            VerticalLayout {
                spacing: 4px;
                alignment: start;
                
                for profile[idx] in profiles : Rectangle {
                    height: 42px;
                    background: Theme.surface;
                    border-radius: Theme.card-radius;
                    // Subscription: cyan border; LocalGroup: purple border; active: brighter
                    border-color: profile.is_active
                        ? (profile.protocol == "LocalGroup" ? Theme.accent-purple : Theme.accent-cyan)
                        : (profile.protocol == "LocalGroup" ? Theme.accent-purple.with-alpha(0.3) : Theme.border);
                    border-width: 1px;
                    
                    HorizontalLayout {
                        padding-left: Theme.card-padding;
                        padding-right: Theme.card-padding;
                        alignment: space-between;
                        
                        // Left: active dot + name + subtitle row
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: profile.is_active
                                        ? (profile.protocol == "LocalGroup" ? Theme.accent-purple : Theme.accent-cyan)
                                        : Theme.text-secondary;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                
                                Text {
                                    text: profile.name;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-primary;
                                    font-weight: 600;
                                    overflow: elide;
                                }
                                
                                // Subscription shows "Updated: <ts>" / LocalGroup shows "Local Group"
                                HorizontalLayout {
                                    spacing: 4px;
                                    Text {
                                        text: profile.protocol == "LocalGroup" ? "Local Group" : ("Updated: " + profile.delay);
                                        color: profile.protocol == "LocalGroup" ? Theme.accent-purple : Theme.text-secondary;
                                        font-size: Theme.font-metadata;
                                        font-weight: profile.protocol == "LocalGroup" ? 600 : 400;
                                    }
                                    // Lock icon badge for Subscription (read-only indicator)
                                    if profile.protocol == "Subscription" : Text {
                                        text: "🔒";
                                        font-size: 7px;
                                        vertical-alignment: center;
                                        color: Theme.text-secondary;
                                    }
                                }
                            }
                        }

                        // Right: Vertical Ellipsis menu trigger
                        VerticalLayout {
                            alignment: center;
                            
                            Rectangle {
                                width: 24px;
                                height: 24px;
                                border-radius: 12px;
                                background: transparent;
                                
                                TouchArea {
                                    clicked => {
                                        root.show-sub-menu(
                                            profile.id,
                                            profile.name,
                                            profile.address,
                                            profile.protocol  // passes "Subscription" or "LocalGroup"
                                        );
                                    }
                                    
                                    Text {
                                        text: "⋮";
                                        color: Theme.text-primary;
                                        font-size: 16px;
                                        font-weight: 800;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
