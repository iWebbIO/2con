import { Theme } from "../components/theme.slint";
import { Icons, Icon } from "../components/icons.slint";

export component AboutScreen inherits Rectangle {
    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-lg;
        alignment: center;

        // Logo / Icon
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 80px;
                height: 80px;
                background: Theme.accent;
                border-radius: 40px;
                
                Text {
                    text: "2C";
                    color: #ffffff;
                    font-size: 32px;
                    font-weight: 800;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        // App Details
        VerticalLayout {
            spacing: 8px;
            alignment: center;

            Text {
                text: "2con Desktop Client";
                color: Theme.text-primary;
                font-size: 22px;
                font-weight: 700;
                horizontal-alignment: center;
            }

            Text {
                text: "Version 1.0.0 (Rust + Slint)";
                color: Theme.text-secondary;
                font-size: 14px;
                horizontal-alignment: center;
            }

            Text {
                text: "A premium proxy manager powered by xray-core & sing-box";
                color: Theme.text-muted;
                font-size: 12px;
                horizontal-alignment: center;
            }
        }

        // Links / Credits Card
        HorizontalLayout {
            alignment: center;
            Rectangle {
                background: Theme.surface;
                border-radius: Theme.card-radius;
                width: 320px;
                height: 120px;

                VerticalLayout {
                    padding: Theme.card-padding;
                    spacing: 12px;
                    alignment: center;

                    Text {
                        text: "License: MIT License";
                        color: Theme.text-primary;
                        font-size: 12px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Frameworks: Slint UI & Tokio Async Engine";
                        color: Theme.text-primary;
                        font-size: 12px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "GitHub: github.com/iWebbIO/2con";
                        color: Theme.accent;
                        font-size: 12px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }
}
