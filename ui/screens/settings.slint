import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export component SettingsScreen inherits Rectangle {
    in-out property <string> core-type: "sing-box";
    in-out property <bool> system-proxy-enabled: false;
    in-out property <bool> tun-enabled: false;
    in-out property <int> socks-port: 20808;
    in-out property <int> http-port: 20809;
    in-out property <string> dns-server: "8.8.8.8";
    in-out property <string> routing-preset: "Bypass LAN & China";
    
    callback toggle-system-proxy(bool);
    callback toggle-tun(bool);
    callback save-settings(string, string, string, string, string); // core, socks, http, dns, route_preset
    callback trigger-about();

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;

        // Title and About Button in header
        HorizontalLayout {
            alignment: space-between;
            height: 28px;
            
            Text {
                text: "Settings";
                color: Theme.text-primary;
                font-size: Theme.font-header;
                font-weight: 800;
                vertical-alignment: center;
            }

            IconButton {
                icon-source: Icons.nav-about;
                text: "About";
                background-color: Theme.elevated;
                hover-background-color: Theme.elevated.brighter(10%);
                active-background-color: Theme.surface;
                width: 60px;
                height: 24px;
                clicked => { root.trigger-about(); }
            }
        }

        Flickable {
            viewport-height: 420px;

            VerticalLayout {
                spacing: Theme.gap-md;
                alignment: start;

                // Network Integration Section
                Rectangle {
                    background: Theme.surface;
                    border-radius: Theme.card-radius;
                    border-width: 1px;
                    border-color: Theme.border;
                    
                    VerticalLayout {
                        padding: Theme.card-padding;
                        spacing: Theme.gap-md;
                        
                        Text { text: "Network Integration"; color: Theme.text-primary; font-size: Theme.font-primary; font-weight: 600; }
                        
                        // System Proxy Row
                        HorizontalLayout {
                            alignment: space-between;
                            Text { text: "System Proxy"; color: Theme.text-secondary; font-size: Theme.font-primary; vertical-alignment: center; }
                            
                            // Toggle switch
                            Rectangle {
                                width: 44px;
                                height: 22px;
                                background: root.system-proxy-enabled ? Theme.accent-cyan : Theme.elevated;
                                border-radius: 11px;
                                
                                TouchArea {
                                    clicked => {
                                        root.system-proxy-enabled = !root.system-proxy-enabled;
                                        root.toggle-system-proxy(root.system-proxy-enabled);
                                    }
                                }
                                
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    background: #ffffff;
                                    border-radius: 9px;
                                    x: root.system-proxy-enabled ? 24px : 2px;
                                    y: 2px;
                                    
                                    animate x {
                                        duration: 120ms;
                                        easing: ease-in-out;
                                    }
                                }
                            }
                        }

                        // TUN Mode Row
                        HorizontalLayout {
                            alignment: space-between;
                            Text { text: "TUN Mode"; color: Theme.text-secondary; font-size: Theme.font-primary; vertical-alignment: center; }
                            
                            // Toggle switch
                            Rectangle {
                                width: 44px;
                                height: 22px;
                                background: root.tun-enabled ? Theme.accent-cyan : Theme.elevated;
                                border-radius: 11px;
                                
                                TouchArea {
                                    clicked => {
                                        root.tun-enabled = !root.tun-enabled;
                                        root.toggle-tun(root.tun-enabled);
                                    }
                                }
                                
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    background: #ffffff;
                                    border-radius: 9px;
                                    x: root.tun-enabled ? 24px : 2px;
                                    y: 2px;
                                    
                                    animate x {
                                        duration: 120ms;
                                        easing: ease-in-out;
                                    }
                                }
                            }
                        }
                    }
                }

                // Core & Routing Section (Segmented Controls)
                Rectangle {
                    background: Theme.surface;
                    border-radius: Theme.card-radius;
                    border-width: 1px;
                    border-color: Theme.border;
                    
                    VerticalLayout {
                        padding: Theme.card-padding;
                        spacing: Theme.gap-md;
                        
                        Text { text: "Engine & Routing"; color: Theme.text-primary; font-size: Theme.font-primary; font-weight: 600; }
                        
                        // Core Select Segmented Control
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "Core Engine"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                            
                            HorizontalLayout {
                                spacing: 4px;
                                height: 24px;
                                
                                Rectangle {
                                    background: root.core-type == "sing-box" ? Theme.accent-cyan : Theme.elevated;
                                    border-radius: 4px;
                                    
                                    TouchArea {
                                        clicked => { root.core-type = "sing-box"; }
                                    }
                                    
                                    Text {
                                        text: "Sing-box";
                                        color: root.core-type == "sing-box" ? #030005 : Theme.text-primary;
                                        font-size: Theme.font-metadata;
                                        font-weight: 700;
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                    }
                                }

                                Rectangle {
                                    background: root.core-type == "xray" ? Theme.accent-cyan : Theme.elevated;
                                    border-radius: 4px;
                                    
                                    TouchArea {
                                        clicked => { root.core-type = "xray"; }
                                    }
                                    
                                    Text {
                                        text: "Xray-core";
                                        color: root.core-type == "xray" ? #030005 : Theme.text-primary;
                                        font-size: Theme.font-metadata;
                                        font-weight: 700;
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                    }
                                }
                            }
                        }

                        // Routing Preset Segmented Control
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "Routing Mode"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                            
                            HorizontalLayout {
                                spacing: 4px;
                                height: 24px;
                                
                                Rectangle {
                                    background: root.routing-preset == "Bypass LAN & China" ? Theme.accent-cyan : Theme.elevated;
                                    border-radius: 4px;
                                    
                                    TouchArea {
                                        clicked => { root.routing-preset = "Bypass LAN & China"; }
                                    }
                                    
                                    Text {
                                        text: "Bypass China";
                                        color: root.routing-preset == "Bypass LAN & China" ? #030005 : Theme.text-primary;
                                        font-size: Theme.font-metadata;
                                        font-weight: 700;
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                    }
                                }

                                Rectangle {
                                    background: root.routing-preset == "Global" ? Theme.accent-cyan : Theme.elevated;
                                    border-radius: 4px;
                                    
                                    TouchArea {
                                        clicked => { root.routing-preset = "Global"; }
                                    }
                                    
                                    Text {
                                        text: "Global";
                                        color: root.routing-preset == "Global" ? #030005 : Theme.text-primary;
                                        font-size: Theme.font-metadata;
                                        font-weight: 700;
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                    }
                                }
                            }
                        }
                    }
                }

                // Inbounds Details (Socks, Http, DNS)
                Rectangle {
                    background: Theme.surface;
                    border-radius: Theme.card-radius;
                    border-width: 1px;
                    border-color: Theme.border;
                    
                    VerticalLayout {
                        padding: Theme.card-padding;
                        spacing: Theme.gap-md;
                        
                        Text { text: "Connection Ports & DNS"; color: Theme.text-primary; font-size: Theme.font-primary; font-weight: 600; }
                        
                        // SOCKS Input
                        VerticalLayout {
                            spacing: 2px;
                            Text { text: "SOCKS Port"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                            SocksInput := TextInput {
                                text: root.socks-port;
                                color: Theme.text-primary;
                                font-size: Theme.font-primary;
                                single-line: true;
                                font-family: "monospace";
                            }
                            Rectangle { height: 1px; background: Theme.border; }
                        }

                        // HTTP Input
                        VerticalLayout {
                            spacing: 2px;
                            Text { text: "HTTP Port"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                            HttpInput := TextInput {
                                text: root.http-port;
                                color: Theme.text-primary;
                                font-size: Theme.font-primary;
                                single-line: true;
                                font-family: "monospace";
                            }
                            Rectangle { height: 1px; background: Theme.border; }
                        }

                        // DNS Server Input
                        VerticalLayout {
                            spacing: 2px;
                            Text { text: "Primary DNS"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                            DnsInput := TextInput {
                                text: root.dns-server;
                                color: Theme.text-primary;
                                font-size: Theme.font-primary;
                                single-line: true;
                                font-family: "monospace";
                            }
                            Rectangle { height: 1px; background: Theme.border; }
                        }
                    }
                }

                // Save Configs Button
                IconButton {
                    icon-source: Icons.save;
                    text: "Save Configuration";
                    background-color: Theme.accent-cyan;
                    hover-background-color: Theme.accent-cyan.brighter(10%);
                    active-background-color: Theme.accent-cyan.darker(15%);
                    height: 36px;
                    clicked => {
                        root.save-settings(
                            root.core-type,
                            SocksInput.text,
                            HttpInput.text,
                            DnsInput.text,
                            root.routing-preset
                        );
                    }
                }
            }
        }
    }
}
