import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export component HomeScreen inherits Rectangle {
    in property <string> connection-status: "Disconnected";
    in property <string> active-profile: "No Profile Selected";
    in property <string> routing-mode: "Bypass LAN & China";
    in property <string> download-speed: "0 KB/s";
    in property <string> upload-speed: "0 KB/s";
    in property <string> total-download: "0 MB";
    in property <string> total-upload: "0 MB";
    in property <bool> is-connected: false;
    in property <bool> is-connecting: false;
    
    callback toggle-connection();
    callback trigger-quick-select();
    callback trigger-logs();

    background: Theme.background;

    // Header Area with Title and Floating Logs Console Button
    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;
        alignment: start;

        // Top Bar
        HorizontalLayout {
            alignment: space-between;
            height: 32px;
            
            Text {
                text: "2con Client";
                color: Theme.text-primary;
                font-size: Theme.font-header;
                font-weight: 800;
                vertical-alignment: center;
            }

            // Floating logs overlay trigger
            IconButton {
                icon-source: Icons.nav-logs;
                icon-size: 14px;
                background-color: Theme.elevated;
                hover-background-color: Theme.elevated.brighter(10%);
                active-background-color: Theme.surface;
                width: 32px;
                height: 32px;
                clicked => { root.trigger-logs(); }
            }
        }

        // Spacer to push content down slightly but keep it centered
        Rectangle { height: 16px; }

        // Centralized Connection Toggle Section
        VerticalLayout {
            alignment: center;
            spacing: Theme.gap-lg;

            // Connection Toggle Button
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 140px;
                    height: 140px;
                    border-radius: 70px;
                    background: is-connected ? Theme.success.with-alpha(0.12) : (is-connecting ? Theme.warning.with-alpha(0.12) : Theme.surface);
                    border-color: is-connected ? Theme.success : (is-connecting ? Theme.warning : Theme.elevated);
                    border-width: 3px;
                    
                    TouchArea {
                        clicked => { root.toggle-connection(); }
                    }
                    
                    VerticalLayout {
                        width: 100%;
                        height: 100%;
                        alignment: center;
                        spacing: Theme.gap-md;
                        
                        HorizontalLayout {
                            alignment: center;
                            Icon {
                                icon-source: is-connected ? Icons.check : Icons.connect;
                                icon-color: is-connected ? Theme.success : (is-connecting ? Theme.warning : Theme.text-primary);
                                size: 36px;
                            }
                        }

                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: is-connected ? "Connected" : (is-connecting ? "Connecting..." : "Disconnected");
                                color: Theme.text-primary;
                                font-size: Theme.font-primary;
                                font-weight: 700;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: is-connected ? "Tap to Stop" : "Tap to Start";
                                color: Theme.text-secondary;
                                font-size: Theme.font-metadata;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }

            // Clickable Quick-Select Pill (Routing Preset & Active Profile)
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    background: Theme.surface;
                    border-radius: Theme.card-radius;
                    border-width: 1px;
                    border-color: Theme.elevated;
                    height: 28px;
                    width: 260px;
                    
                    TouchArea {
                        clicked => { root.trigger-quick-select(); }
                    }
                    
                    HorizontalLayout {
                        width: 100%;
                        height: 100%;
                        alignment: center;
                        spacing: 8px;
                        padding-left: 10px;
                        padding-right: 10px;
                        
                        Text {
                            text: routing-mode;
                            color: Theme.accent;
                            font-size: Theme.font-metadata;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        
                        Rectangle {
                            width: 1px;
                            height: 10px;
                            background: Theme.elevated;
                        }
                        
                        Text {
                            text: active-profile;
                            color: Theme.text-primary;
                            font-size: Theme.font-metadata;
                            font-weight: 600;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
            }
        }

        Rectangle { height: 12px; }

        // Condensed Traffic Stats Panel
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.card-radius;
            height: 48px;
            
            HorizontalLayout {
                padding-left: Theme.card-padding;
                padding-right: Theme.card-padding;
                alignment: space-around;
                
                // Uplink Speed & Total
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    
                    Icon {
                        icon-source: Icons.upload;
                        icon-color: Theme.warning;
                        size: 14px;
                    }
                    
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: upload-speed;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            font-weight: 700;
                        }
                        Text {
                            text: "Total: " + total-upload;
                            color: Theme.text-muted;
                            font-size: Theme.font-metadata;
                        }
                    }
                }

                // Divider line
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.elevated;
                    }
                }

                // Downlink Speed & Total
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    
                    Icon {
                        icon-source: Icons.download;
                        icon-color: Theme.accent;
                        size: 14px;
                    }
                    
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: download-speed;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            font-weight: 700;
                        }
                        Text {
                            text: "Total: " + total-download;
                            color: Theme.text-muted;
                            font-size: Theme.font-metadata;
                        }
                    }
                }
            }
        }
    }
}
