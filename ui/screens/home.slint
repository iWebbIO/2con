import { Theme } from "../components/theme.slint";
import { Icons, Icon } from "../components/icons.slint";

export component HomeScreen inherits Rectangle {
    in property <string> connection-status: "Disconnected";
    in property <string> active-profile: "No Profile Selected";
    in property <string> download-speed: "0 KB/s";
    in property <string> upload-speed: "0 KB/s";
    in property <string> total-download: "0 MB";
    in property <string> total-upload: "0 MB";
    in property <bool> is-connected: false;
    in property <bool> is-connecting: false;
    
    callback toggle-connection();

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-lg;

        // Top Info Bar
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.card-radius;
            height: 60px;
            
            HorizontalLayout {
                padding-left: Theme.card-padding;
                padding-right: Theme.card-padding;
                alignment: space-between;
                
                // Active Profile Info
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    
                    Text {
                        text: "Profile:";
                        color: Theme.text-secondary;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: active-profile;
                        color: Theme.text-primary;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // Core Stats / Delay (Mock or actual)
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    
                    Text {
                        text: is-connected ? "System Proxy Active" : "Proxy Inactive";
                        color: is-connected ? Theme.success : Theme.text-secondary;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Circular Connect Button Section
        VerticalLayout {
            alignment: center;
            spacing: Theme.gap-md;
            
            Rectangle {
                width: 180px;
                height: 180px;
                background: is-connected ? #0f3d30 : (is-connecting ? #3d300f : #2c1a24);
                border-radius: 90px;
                border-color: is-connected ? Theme.success : (is-connecting ? Theme.warning : Theme.danger);
                border-width: 4px;
                
                // Connect/Disconnect inner button action
                TouchArea {
                    clicked => { root.toggle-connection(); }
                    
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        
                        // Icon Placeholder (Visual status)
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            border-radius: 20px;
                            background: is-connected ? Theme.success : (is-connecting ? Theme.warning : Theme.danger);
                            
                            Icon {
                                icon-source: is-connected ? Icons.check : Icons.connect;
                                icon-color: Theme.background;
                                size: 24px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }

                        Text {
                            text: is-connected ? "Connected" : (is-connecting ? "Connecting..." : "Tap to Connect");
                            color: Theme.text-primary;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: is-connected ? "Click to Disconnect" : "Core Stopped";
                            color: Theme.text-secondary;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // Traffic Stats Panel
        HorizontalLayout {
            spacing: Theme.gap-md;
            height: 100px;
            
            // Downlink Card
            Rectangle {
                background: Theme.surface;
                border-radius: Theme.card-radius;
                
                VerticalLayout {
                    padding: Theme.card-padding;
                    alignment: space-around;
                    
                    HorizontalLayout {
                        spacing: 8px;
                        Icon {
                            icon-source: Icons.download;
                            icon-color: Theme.accent;
                            size: 18px;
                        }
                        Text { text: "Download Speed"; color: Theme.text-secondary; font-size: 12px; }
                    }
                    Text {
                        text: download-speed;
                        color: Theme.text-primary;
                        font-size: 20px;
                        font-weight: 700;
                    }
                    Text {
                        text: "Total: " + total-download;
                        color: Theme.text-muted;
                        font-size: 11px;
                    }
                }
            }

            // Uplink Card
            Rectangle {
                background: Theme.surface;
                border-radius: Theme.card-radius;
                
                VerticalLayout {
                    padding: Theme.card-padding;
                    alignment: space-around;
                    
                    HorizontalLayout {
                        spacing: 8px;
                        Icon {
                            icon-source: Icons.upload;
                            icon-color: Theme.warning;
                            size: 18px;
                        }
                        Text { text: "Upload Speed"; color: Theme.text-secondary; font-size: 12px; }
                    }
                    Text {
                        text: upload-speed;
                        color: Theme.text-primary;
                        font-size: 20px;
                        font-weight: 700;
                    }
                    Text {
                        text: "Total: " + total-upload;
                        color: Theme.text-muted;
                        font-size: 11px;
                    }
                }
            }
        }

        // Bottom space filler
        Rectangle {
            background: transparent;
        }
    }
}
