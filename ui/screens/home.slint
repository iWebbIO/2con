import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export component HomeScreen inherits Rectangle {
    in property <string> connection_status: "disconnected";
    in property <string> active-profile: "No Profile Selected";
    in property <string> routing-mode: "Bypass LAN & China";
    in property <string> download-speed: "0 KB/s";
    in property <string> upload-speed: "0 KB/s";
    in property <string> total-download: "0 MB";
    in property <string> total-upload: "0 MB";
    in property <bool> is-connected: false;
    in property <bool> is-connecting: false;
    
    callback toggle-connection();
    callback trigger-quick-select();
    callback trigger-logs();

    background: Theme.background;

    // Header Area with Title and Floating Logs Console Button
    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;
        alignment: start;

        // Top Bar
        HorizontalLayout {
            alignment: space-between;
            height: 32px;
            
            Text {
                text: "2con Client";
                color: Theme.text-primary;
                font-size: Theme.font-header;
                font-weight: 800;
                vertical-alignment: center;
            }

            // Floating logs overlay trigger
            IconButton {
                icon-source: Icons.nav-logs;
                icon-size: 14px;
                background-color: Theme.elevated;
                hover-background-color: Theme.elevated.brighter(10%);
                active-background-color: Theme.surface;
                width: 32px;
                height: 32px;
                clicked => { root.trigger-logs(); }
            }
        }

        // Spacer to push content down slightly but keep it centered
        Rectangle { height: 16px; }

        // Centralized Connection Toggle Section
        VerticalLayout {
            alignment: center;
            spacing: Theme.gap-lg;

            // Connection Toggle Button (Neon Gradient Border + DropShadow Glow)
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 140px;
                    height: 140px;
                    border-radius: 70px;
                    background: @linear-gradient(135deg, Theme.accent-purple 0%, Theme.accent-magenta 100%);
                    
                    // Neon Glow DropShadow
                    drop-shadow-color: root.connection_status == "connected" ? Theme.accent-cyan.with-alpha(0.25) : (root.connection_status == "timeout" ? Theme.error-red.with-alpha(0.35) : Theme.accent-purple.with-alpha(0.2));
                    drop-shadow-offset-x: 0;
                    drop-shadow-offset-y: 4px;
                    drop-shadow-blur: 14px;
                    
                    TouchArea {
                        clicked => { root.toggle-connection(); }
                    }
                    
                    Rectangle {
                        x: 3px;
                        y: 3px;
                        width: 134px;
                        height: 134px;
                        border-radius: 67px;
                        background: root.connection_status == "connected" ? rgba(0, 229, 255, 0.06) : Theme.background;
                        
                        VerticalLayout {
                            width: 100%;
                            height: 100%;
                            alignment: center;
                            spacing: Theme.gap-md;
                            
                            HorizontalLayout {
                                alignment: center;
                                Icon {
                                    icon-source: root.connection_status == "connected" ? Icons.check : Icons.connect;
                                    icon-color: root.connection_status == "connected" ? Theme.accent-cyan : (root.connection_status == "timeout" ? Theme.error-red : Theme.text-primary);
                                    size: 36px;
                                }
                            }

                            VerticalLayout {
                                spacing: 2px;
                                Text {
                                    text: root.connection_status == "connected" ? "Connected" : (root.connection_status == "timeout" ? "Timeout" : (root.is-connecting ? "Connecting..." : "Disconnected"));
                                    color: root.connection_status == "connected" ? Theme.accent-cyan : (root.connection_status == "timeout" ? Theme.error-red : Theme.text-primary);
                                    font-size: Theme.font-primary;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.connection_status == "connected" ? "Tap to Stop" : "Tap to Start";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-metadata;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            // Clickable Quick-Select Pill (Translucent overlay style)
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    background: rgba(20, 10, 30, 0.55);
                    border-radius: 14px;
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.08);
                    height: 28px;
                    width: 260px;
                    
                    TouchArea {
                        clicked => { root.trigger-quick-select(); }
                    }
                    
                    HorizontalLayout {
                        width: 100%;
                        height: 100%;
                        alignment: center;
                        spacing: 8px;
                        padding-left: 12px;
                        padding-right: 12px;
                        
                        Text {
                            text: routing-mode;
                            color: Theme.accent-cyan;
                            font-size: Theme.font-metadata;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        
                        Rectangle {
                            width: 1px;
                            height: 10px;
                            background: rgba(255, 255, 255, 0.1);
                        }
                        
                        Text {
                            text: active-profile;
                            color: Theme.text-primary;
                            font-size: Theme.font-metadata;
                            font-weight: 600;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
            }
        }

        Rectangle { height: 12px; }

        // Condensed Traffic Stats Panel
        Rectangle {
            background: Theme.surface;
            border-radius: Theme.card-radius;
            border-width: 1px;
            border-color: Theme.border;
            height: 48px;
            
            HorizontalLayout {
                padding-left: Theme.card-padding;
                padding-right: Theme.card-padding;
                alignment: space-around;
                
                // Uplink Speed & Total
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    
                    Icon {
                        icon-source: Icons.upload;
                        icon-color: Theme.accent-magenta;
                        size: 14px;
                    }
                    
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: upload-speed;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            font-weight: 700;
                            font-family: "monospace";
                        }
                        Text {
                            text: "Total: " + total-upload;
                            color: Theme.text-secondary;
                            font-size: Theme.font-metadata;
                            font-family: "monospace";
                        }
                    }
                }

                // Divider line
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.border;
                    }
                }

                // Downlink Speed & Total
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    
                    Icon {
                        icon-source: Icons.download;
                        icon-color: Theme.accent-cyan;
                        size: 14px;
                    }
                    
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: download-speed;
                            color: Theme.text-primary;
                            font-size: Theme.font-primary;
                            font-weight: 700;
                            font-family: "monospace";
                        }
                        Text {
                            text: "Total: " + total-download;
                            color: Theme.text-secondary;
                            font-size: Theme.font-metadata;
                            font-family: "monospace";
                        }
                    }
                }
            }
        }
    }
}
