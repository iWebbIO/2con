import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export component LogsScreen inherits Rectangle {
    in property <[string]> logs: [];
    callback clear-logs();

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;

        // Title and Actions
        HorizontalLayout {
            alignment: space-between;
            
            Text {
                text: "Real-time Logs";
                color: Theme.text-primary;
                font-size: 20px;
                font-weight: 700;
            }

            IconButton {
                icon-source: Icons.delete;
                text: "Clear Logs";
                background-color: Theme.danger;
                hover-background-color: Theme.danger.brighter(10%);
                active-background-color: Theme.danger.darker(15%);
                width: 120px;
                height: 32px;
                clicked => { root.clear-logs(); }
            }
        }

        // Terminal Console Area
        Rectangle {
            background: #0f1015;
            border-radius: Theme.card-radius;
            border-width: 1px;
            border-color: Theme.elevated;
            
            Flickable {
                viewport-height: logs.length * 20px + 20px;
                
                VerticalLayout {
                    padding: Theme.card-padding;
                    alignment: start;
                    spacing: 4px;
                    
                    for log-line[idx] in logs : Text {
                        text: log-line;
                        color: Theme.text-secondary;
                        font-family: "Courier New";
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
