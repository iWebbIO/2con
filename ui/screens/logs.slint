import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export component LogsScreen inherits Rectangle {
    in property <[string]> logs: [];
    callback clear-logs();
    callback copy-logs();
    callback close();

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;

        // Title and Actions
        HorizontalLayout {
            alignment: space-between;
            height: 28px;
            
            HorizontalLayout {
                spacing: 8px;
                
                IconButton {
                    text: "Close";
                    background-color: Theme.elevated;
                    hover-background-color: Theme.elevated.brighter(10%);
                    active-background-color: Theme.surface;
                    width: 50px;
                    height: 26px;
                    clicked => { root.close(); }
                }
                
                Text {
                    text: "Logs Console";
                    color: Theme.text-primary;
                    font-size: Theme.font-header;
                    font-weight: 800;
                    vertical-alignment: center;
                }
            }

            IconButton {
                icon-source: Icons.delete;
                text: "Clear";
                background-color: Theme.danger;
                hover-background-color: Theme.danger.brighter(10%);
                active-background-color: Theme.danger.darker(15%);
                width: 60px;
                height: 26px;
                clicked => { root.clear-logs(); }
            }
        }

        // Terminal Console Area
        Rectangle {
            background: #0f1015;
            border-radius: Theme.card-radius;
            border-width: 1px;
            border-color: Theme.elevated;
            
            Flickable {
                viewport-height: logs.length * 22px + 20px;
                
                VerticalLayout {
                    padding: Theme.card-padding;
                    alignment: start;
                    spacing: 4px;
                    
                    for log-line[idx] in logs : Text {
                        text: log-line;
                        color: Theme.text-secondary;
                        font-family: "Courier New";
                        font-size: Theme.font-metadata;
                        wrap: word-wrap; // Automatic text wrapping for 1:1 viewports
                    }
                }
            }

            // Floating Copy Button in top right corner
            Rectangle {
                x: parent.width - self.width - 8px;
                y: 8px;
                width: 28px;
                height: 28px;
                border-radius: 4px;
                background: Theme.surface.with-alpha(0.85);
                border-width: 1px;
                border-color: Theme.elevated;
                
                TouchArea {
                    clicked => { root.copy-logs(); }
                    
                    Icon {
                        icon-source: Icons.clipboard;
                        icon-color: Theme.text-primary;
                        size: 14px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }
        }
    }
}
