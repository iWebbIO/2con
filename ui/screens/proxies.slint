import { Theme } from "../components/theme.slint";
import { Icons, Icon, IconButton } from "../components/icons.slint";

export struct ProxyUiItem {
    id: int,
    name: string,
    protocol: string,
    delay: string,
    is_active: bool,
}

export component ProxiesScreen inherits Rectangle {
    in property <[ProxyUiItem]> proxies: [];
    callback select-proxy(int);
    callback test-all-latency();

    background: Theme.background;

    VerticalLayout {
        padding: Theme.padding-screen;
        spacing: Theme.gap-md;

        // Top actions / summary
        HorizontalLayout {
            alignment: space-between;
            
            Text {
                text: "Select Outbound Proxy Node";
                color: Theme.text-primary;
                font-size: 20px;
                font-weight: 700;
            }

            IconButton {
                icon-source: Icons.nav-proxies;
                text: "Test Latencies";
                background-color: Theme.accent;
                hover-background-color: Theme.accent.brighter(10%);
                active-background-color: Theme.accent.darker(15%);
                width: 140px;
                height: 32px;
                clicked => { root.test-all-latency(); }
            }
        }

        // Scrollable Grid/List of Proxies
        Flickable {
            viewport-height: (proxies.length + 1) / 2 * 65px;
            
            VerticalLayout {
                spacing: 8px;
                
                // Representing proxies in a list layout
                for proxy[idx] in proxies : Rectangle {
                    height: 55px;
                    background: proxy.is-active ? Theme.elevated : Theme.surface;
                    border-radius: Theme.card-radius;
                    border-color: proxy.is-active ? Theme.accent : transparent;
                    border-width: 1px;
                    
                    TouchArea {
                        clicked => { root.select-proxy(proxy.id); }
                        
                        HorizontalLayout {
                            padding-left: Theme.card-padding;
                            padding-right: Theme.card-padding;
                            spacing: 12px;
                            alignment: space-between;
                            
                            HorizontalLayout {
                                spacing: 12px;
                                alignment: start;
                                
                                // Protocol Indicator Dot (Centered Vertically)
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 4px;
                                        background: proxy.is-active ? Theme.success : Theme.text-secondary;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    
                                    Text {
                                        text: proxy.name;
                                        color: Theme.text-primary;
                                        font-size: 14px;
                                        font-weight: 600;
                                    }
                                    
                                    Text {
                                        text: proxy.protocol;
                                        color: Theme.text-secondary;
                                        font-size: 11px;
                                    }
                                }
                            }

                            // Latency Speed display (Centered Vertically)
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    background: proxy.delay == "" ? Theme.elevated : (proxy.delay == "Timeout" ? #742a2a : #22543d);
                                    border-radius: 4px;
                                    height: 22px;
                                    
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        alignment: center;
                                        
                                        Text {
                                            text: proxy.delay == "" ? "Not Tested" : proxy.delay;
                                            color: proxy.delay == "" ? Theme.text-secondary : (proxy.delay == "Timeout" ? #fed7d7 : #c6f6d5);
                                            font-size: 11px;
                                            font-weight: 700;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
