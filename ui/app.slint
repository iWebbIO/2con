import { HomeScreen } from "screens/home.slint";
import { ProfilesScreen, ProfileUiItem } from "screens/profiles.slint";
import { ProxiesScreen, ProxyUiItem } from "screens/proxies.slint";
import { SettingsScreen } from "screens/settings.slint";
import { LogsScreen } from "screens/logs.slint";
import { AboutScreen } from "screens/about.slint";
import { Theme } from "components/theme.slint";
import { Icons, Icon, IconButton } from "components/icons.slint";

export { ProfileUiItem, ProxyUiItem }

export component AppWindow inherits Window {
    title: "2con Desktop Proxy Client";
    width: 900px;
    height: 620px;
    background: Theme.background;

    // Global Properties
    in-out property <int> active-page-index: 0;

    // Home Properties
    in-out property <string> connection-status: "Disconnected";
    in-out property <string> active-profile: "No Profile Selected";
    in-out property <string> download-speed: "0 KB/s";
    in-out property <string> upload-speed: "0 KB/s";
    in-out property <string> total-download: "0 MB";
    in-out property <string> total-upload: "0 MB";
    in-out property <bool> is-connected: false;
    in-out property <bool> is-connecting: false;

    // Profiles Properties
    in-out property <[ProfileUiItem]> profiles: [];

    // Proxies Properties
    in-out property <[ProxyUiItem]> proxies: [];

    // Settings Properties
    in-out property <string> core-type: "sing-box";
    in-out property <bool> system-proxy-enabled: false;
    in-out property <bool> tun-enabled: false;
    in-out property <int> socks-port: 20808;
    in-out property <int> http-port: 20809;
    in-out property <string> dns-server: "8.8.8.8";
    in-out property <string> routing-preset: "Bypass LAN & China";

    // Logs
    in-out property <[string]> logs: [];

    // Callbacks to Rust
    callback toggle-connection();
    callback select-profile(int);
    callback delete-profile(int);
    callback ping-profile(int);
    callback import-subscription(string, string);
    callback import-clipboard();
    callback select-proxy(int);
    callback test-all-latency();
    callback toggle-system-proxy(bool);
    callback toggle-tun(bool);
    callback save-settings(string, string, string, string, string);
    callback clear-logs();

    HorizontalLayout {
        // Navigation Rail (Left Side)
        Rectangle {
            width: 80px;
            background: Theme.surface;
            
            VerticalLayout {
                padding-top: Theme.padding-screen;
                padding-bottom: Theme.padding-screen;
                spacing: Theme.nav-spacing;
                alignment: start;

                // Brand Icon
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 44px;
                        height: 44px;
                        border-radius: 22px;
                        background: Theme.accent;
                        
                        Text {
                            text: "2C";
                            color: #ffffff;
                            font-size: 16px;
                            font-weight: 900;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                }

                Rectangle { height: 10px; } // spacer

                // Home Nav Item
                VerticalLayout {
                    spacing: 4px;
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 50px;
                            height: 50px;
                            border-radius: 10px;
                            background: root.active-page-index == 0 ? Theme.elevated : transparent;
                            
                            TouchArea {
                                clicked => { root.active-page-index = 0; }
                                Icon {
                                    icon-source: Icons.nav-home;
                                    icon-color: root.active-page-index == 0 ? Theme.text-primary : Theme.text-secondary;
                                    size: 24px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                        }
                    }
                    Text { text: "Home"; color: root.active-page-index == 0 ? Theme.text-primary : Theme.text-secondary; font-size: 10px; font-weight: 600; horizontal-alignment: center; }
                }

                // Profiles Nav Item
                VerticalLayout {
                    spacing: 4px;
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 50px;
                            height: 50px;
                            border-radius: 10px;
                            background: root.active-page-index == 1 ? Theme.elevated : transparent;
                            
                            TouchArea {
                                clicked => { root.active-page-index = 1; }
                                Icon {
                                    icon-source: Icons.nav-profiles;
                                    icon-color: root.active-page-index == 1 ? Theme.text-primary : Theme.text-secondary;
                                    size: 24px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                        }
                    }
                    Text { text: "Profiles"; color: root.active-page-index == 1 ? Theme.text-primary : Theme.text-secondary; font-size: 10px; font-weight: 600; horizontal-alignment: center; }
                }

                // Proxies Nav Item
                VerticalLayout {
                    spacing: 4px;
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 50px;
                            height: 50px;
                            border-radius: 10px;
                            background: root.active-page-index == 2 ? Theme.elevated : transparent;
                            
                            TouchArea {
                                clicked => { root.active-page-index = 2; }
                                Icon {
                                    icon-source: Icons.nav-proxies;
                                    icon-color: root.active-page-index == 2 ? Theme.text-primary : Theme.text-secondary;
                                    size: 24px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                        }
                    }
                    Text { text: "Proxies"; color: root.active-page-index == 2 ? Theme.text-primary : Theme.text-secondary; font-size: 10px; font-weight: 600; horizontal-alignment: center; }
                }

                // Settings Nav Item
                VerticalLayout {
                    spacing: 4px;
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 50px;
                            height: 50px;
                            border-radius: 10px;
                            background: root.active-page-index == 3 ? Theme.elevated : transparent;
                            
                            TouchArea {
                                clicked => { root.active-page-index = 3; }
                                Icon {
                                    icon-source: Icons.nav-settings;
                                    icon-color: root.active-page-index == 3 ? Theme.text-primary : Theme.text-secondary;
                                    size: 24px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                        }
                    }
                    Text { text: "Settings"; color: root.active-page-index == 3 ? Theme.text-primary : Theme.text-secondary; font-size: 10px; font-weight: 600; horizontal-alignment: center; }
                }

                // Logs Nav Item
                VerticalLayout {
                    spacing: 4px;
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 50px;
                            height: 50px;
                            border-radius: 10px;
                            background: root.active-page-index == 4 ? Theme.elevated : transparent;
                            
                            TouchArea {
                                clicked => { root.active-page-index = 4; }
                                Icon {
                                    icon-source: Icons.nav-logs;
                                    icon-color: root.active-page-index == 4 ? Theme.text-primary : Theme.text-secondary;
                                    size: 24px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                        }
                    }
                    Text { text: "Logs"; color: root.active-page-index == 4 ? Theme.text-primary : Theme.text-secondary; font-size: 10px; font-weight: 600; horizontal-alignment: center; }
                }

                // About Nav Item
                VerticalLayout {
                    spacing: 4px;
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 50px;
                            height: 50px;
                            border-radius: 10px;
                            background: root.active-page-index == 5 ? Theme.elevated : transparent;
                            
                            TouchArea {
                                clicked => { root.active-page-index = 5; }
                                Icon {
                                    icon-source: Icons.nav-about;
                                    icon-color: root.active-page-index == 5 ? Theme.text-primary : Theme.text-secondary;
                                    size: 24px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                        }
                    }
                    Text { text: "About"; color: root.active-page-index == 5 ? Theme.text-primary : Theme.text-secondary; font-size: 10px; font-weight: 600; horizontal-alignment: center; }
                }
            }
        }

        // Screen Content (Switched based on active-page-index)
        Rectangle {
            background: Theme.background;
            
            if root.active-page-index == 0 : HomeScreen {
                connection-status: root.connection-status;
                active-profile: root.active-profile;
                download-speed: root.download-speed;
                upload-speed: root.upload-speed;
                total-download: root.total-download;
                total-upload: root.total-upload;
                is-connected: root.is-connected;
                is-connecting: root.is-connecting;
                toggle-connection => { root.toggle-connection(); }
            }
            if root.active-page-index == 1 : ProfilesScreen {
                profiles: root.profiles;
                select-profile(id) => { root.select-profile(id); }
                delete-profile(id) => { root.delete-profile(id); }
                ping-profile(id) => { root.ping-profile(id); }
                import-subscription(name, url) => { root.import-subscription(name, url); }
                import-clipboard => { root.import-clipboard(); }
            }
            if root.active-page-index == 2 : ProxiesScreen {
                proxies: root.proxies;
                select-proxy(id) => { root.select-proxy(id); }
                test-all-latency => { root.test-all-latency(); }
            }
            if root.active-page-index == 3 : SettingsScreen {
                core-type: root.core-type;
                system-proxy-enabled: root.system-proxy-enabled;
                tun-enabled: root.tun-enabled;
                socks-port: root.socks-port;
                http-port: root.http-port;
                dns-server: root.dns-server;
                routing-preset: root.routing-preset;
                toggle-system-proxy(enabled) => { root.toggle-system-proxy(enabled); }
                toggle-tun(enabled) => { root.toggle-tun(enabled); }
                save-settings(core, socks, http, dns, route) => { root.save-settings(core, socks, http, dns, route); }
            }
            if root.active-page-index == 4 : LogsScreen {
                logs: root.logs;
                clear-logs => { root.clear-logs(); }
            }
            if root.active-page-index == 5 : AboutScreen {}
        }
    }
}
