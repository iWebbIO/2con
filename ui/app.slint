import { HomeScreen } from "screens/home.slint";
import { ProfilesScreen, ProfileUiItem } from "screens/profiles.slint";
import { ProxiesScreen, ProxyUiItem } from "screens/proxies.slint";
import { SettingsScreen } from "screens/settings.slint";
import { LogsScreen } from "screens/logs.slint";
import { AboutScreen } from "screens/about.slint";
import { Theme } from "components/theme.slint";
import { Icons, Icon, IconButton } from "components/icons.slint";
import { HorizontalBox } from "std-widgets.slint";

export { ProfileUiItem, ProxyUiItem }

export component AppWindow inherits Window {
    title: "2con client";
    width: 400px;
    height: 400px;
    background: Theme.background;

    // Global Properties
    in-out property <int> active-page-index: 0;

    // Home Properties
    in-out property <string> connection_status: "disconnected"; // values: "disconnected", "connected", "timeout"
    in-out property <string> active-profile: "No Profile Selected";
    in-out property <string> download-speed: "0 KB/s";
    in-out property <string> upload-speed: "0 KB/s";
    in-out property <string> total-download: "0 MB";
    in-out property <string> total-upload: "0 MB";
    in-out property <bool> is-connected: false;
    in-out property <bool> is-connecting: false;

    // Profiles Properties (Subscriptions represented)
    in-out property <[ProfileUiItem]> profiles: [];

    // Proxies Properties
    in-out property <[ProxyUiItem]> proxies: [];

    // Settings Properties
    in-out property <string> core-type: "sing-box";
    in-out property <bool> system-proxy-enabled: false;
    in-out property <bool> tun-enabled: false;
    in-out property <int> socks-port: 20808;
    in-out property <int> http-port: 20809;
    in-out property <string> dns-server: "8.8.8.8";
    in-out property <string> routing-preset: "Bypass LAN & China";

    // Logs
    in-out property <[string]> logs: [];

    // Overlay State Variables
    in-out property <bool> show-logs: false;
    in-out property <bool> show-about: false;
    in-out property <bool> show-quick-select: false;
    in-out property <bool> show-sub-menu: false;
    
    // Selected sub properties for bottom sheet
    in-out property <int> selected-sub-id: -1;
    in-out property <string> selected-sub-name: "";
    in-out property <string> selected-sub-url: "";
    in-out property <string> selected-sub-type: "Subscription"; // "Subscription" or "LocalGroup"

    // Callbacks to Rust
    callback toggle-connection();
    callback select-profile(int);
    callback delete-profile(int);
    callback ping-profile(int);
    callback import-subscription(string, string);
    callback import-clipboard();
    callback select-proxy(int);
    callback test-all-latency();
    callback toggle-system-proxy(bool);
    callback toggle-tun(bool);
    callback save-settings(string, string, string, string, string);
    callback clear-logs();
    callback copy-logs();
    callback copy-text(string);
    callback create-local-group(string);
    callback rename-profile(int, string);
    callback add-config-to-group(int);

    // --- Dynamic Bottom Glow Rectangles (Base z-index) ---
    // 1. Connected Glow (AccentCyan)
    Rectangle {
        x: 0;
        y: parent.height * 60%;
        width: 100%;
        height: parent.height * 40%;
        background: @linear-gradient(180deg, transparent 0%, Theme.accent-cyan 100%);
        opacity: root.connection_status == "connected" ? 0.2 : 0.0;
        
        animate opacity {
            duration: 400ms;
            easing: ease-in-out;
        }
    }
    
    // 2. Timeout Glow (ErrorRed)
    Rectangle {
        x: 0;
        y: parent.height * 60%;
        width: 100%;
        height: parent.height * 40%;
        background: @linear-gradient(180deg, transparent 0%, Theme.error-red 100%);
        opacity: root.connection_status == "timeout" ? 0.3 : 0.0;
        
        animate opacity {
            duration: 400ms;
            easing: ease-in-out;
        }
    }

    // Root Layout Structure
    VerticalLayout {
        // Main Screen Area (Tab switching)
        Rectangle {
            background: transparent;
            
            if root.active-page-index == 0 : HomeScreen {
                connection_status: root.connection_status;
                active-profile: root.active-profile;
                routing-mode: root.routing-preset;
                download-speed: root.download-speed;
                upload-speed: root.upload-speed;
                total-download: root.total-download;
                total-upload: root.total-upload;
                is-connected: root.is-connected;
                is-connecting: root.is-connecting;
                toggle-connection => { root.toggle-connection(); }
                trigger-quick-select => { root.show-quick-select = true; }
                trigger-logs => { root.show-logs = true; }
            }
            if root.active-page-index == 1 : ProxiesScreen {
                proxies: root.proxies;
                select-proxy(id) => { root.select-proxy(id); }
                test-all-latency => { root.test-all-latency(); }
            }
            if root.active-page-index == 2 : ProfilesScreen {
                profiles: root.profiles;
                select-profile(id) => { root.select-profile(id); }
                delete-profile(id) => { root.delete-profile(id); }
                ping-profile(id) => { root.ping-profile(id); }
                import-subscription(name, url) => { root.import-subscription(name, url); }
                import-clipboard => { root.import-clipboard(); }
                create-local-group(name) => { root.create-local-group(name); }
                rename-profile(id, name) => { root.rename-profile(id, name); }
                add-config-to-group(id) => { root.add-config-to-group(id); }
                show-sub-menu(sub-id, name, url, sub-type) => {
                    root.selected-sub-id = sub-id;
                    root.selected-sub-name = name;
                    root.selected-sub-url = url;
                    root.selected-sub-type = sub-type;
                    root.show-sub-menu = true;
                }
            }
            if root.active-page-index == 3 : SettingsScreen {
                core-type: root.core-type;
                system-proxy-enabled: root.system-proxy-enabled;
                tun-enabled: root.tun-enabled;
                socks-port: root.socks-port;
                http-port: root.http-port;
                dns-server: root.dns-server;
                routing-preset: root.routing-preset;
                toggle-system-proxy(enabled) => { root.toggle-system-proxy(enabled); }
                toggle-tun(enabled) => { root.toggle-tun(enabled); }
                save-settings(core, socks, http, dns, route) => { root.save-settings(core, socks, http, dns, route); }
                trigger-about => { root.show-about = true; }
            }
        }

        // Floating Bottom Navigation Bar
        HorizontalBox {
            padding: 12px; // margin so it floats
            height: 76px; // 52px navigation height + 24px margins
            
            Rectangle {
                background: Theme.surface;
                border-radius: 20px;
                border-width: 1px;
                border-color: Theme.border;
                
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: Theme.gap-md;
                    
                    // Tab 0: Home
                    Rectangle {
                        background: root.active-page-index == 0 ? rgba(255, 255, 255, 0.08) : transparent;
                        border-radius: 12px;
                        
                        TouchArea {
                            clicked => { root.active-page-index = 0; }
                        }
                        
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            HorizontalLayout {
                                alignment: center;
                                Icon {
                                    icon-source: Icons.nav-home;
                                    icon-color: root.active-page-index == 0 ? Theme.accent-cyan : Theme.text-secondary;
                                    size: 18px;
                                }
                            }
                            Text {
                                text: "Home";
                                color: root.active-page-index == 0 ? Theme.accent-cyan : Theme.text-secondary;
                                font-size: Theme.font-metadata;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Tab 1: Proxies
                    Rectangle {
                        background: root.active-page-index == 1 ? rgba(255, 255, 255, 0.08) : transparent;
                        border-radius: 12px;
                        
                        TouchArea {
                            clicked => { root.active-page-index = 1; }
                        }
                        
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            HorizontalLayout {
                                alignment: center;
                                Icon {
                                    icon-source: Icons.nav-proxies;
                                    icon-color: root.active-page-index == 1 ? Theme.accent-cyan : Theme.text-secondary;
                                    size: 18px;
                                }
                            }
                            Text {
                                text: "Proxies";
                                color: root.active-page-index == 1 ? Theme.accent-cyan : Theme.text-secondary;
                                font-size: Theme.font-metadata;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Tab 2: Profiles (Subscriptions)
                    Rectangle {
                        background: root.active-page-index == 2 ? rgba(255, 255, 255, 0.08) : transparent;
                        border-radius: 12px;
                        
                        TouchArea {
                            clicked => { root.active-page-index = 2; }
                        }
                        
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            HorizontalLayout {
                                alignment: center;
                                Icon {
                                    icon-source: Icons.nav-profiles;
                                    icon-color: root.active-page-index == 2 ? Theme.accent-cyan : Theme.text-secondary;
                                    size: 18px;
                                }
                            }
                            Text {
                                text: "Profiles";
                                color: root.active-page-index == 2 ? Theme.accent-cyan : Theme.text-secondary;
                                font-size: Theme.font-metadata;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Tab 3: Settings
                    Rectangle {
                        background: root.active-page-index == 3 ? rgba(255, 255, 255, 0.08) : transparent;
                        border-radius: 12px;
                        
                        TouchArea {
                            clicked => { root.active-page-index = 3; }
                        }
                        
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            HorizontalLayout {
                                alignment: center;
                                Icon {
                                    icon-source: Icons.nav-settings;
                                    icon-color: root.active-page-index == 3 ? Theme.accent-cyan : Theme.text-secondary;
                                    size: 18px;
                                }
                            }
                            Text {
                                text: "Settings";
                                color: root.active-page-index == 3 ? Theme.accent-cyan : Theme.text-secondary;
                                font-size: Theme.font-metadata;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // --- Strict Z-Index Slide-up Overlays ---

    // 1. Logs Overlay Console
    Rectangle {
        x: 0;
        y: root.show-logs ? 0 : 400px;
        width: 100%;
        height: 100%;
        background: transparent;
        
        animate y {
            duration: 200ms;
            easing: ease-out;
        }
        
        LogsScreen {
            logs: root.logs;
            clear-logs => { root.clear-logs(); }
            copy-logs => { root.copy-logs(); }
            close => { root.show-logs = false; }
        }
    }

    // 2. About Overlay Sheet
    Rectangle {
        x: 0;
        y: root.show-about ? 0 : 400px;
        width: 100%;
        height: 100%;
        background: transparent;
        
        animate y {
            duration: 200ms;
            easing: ease-out;
        }
        
        AboutScreen {
            close => { root.show-about = false; }
        }
    }

    // 3. Routing Quick-Select Bottom Sheet
    Rectangle {
        x: 0;
        y: root.show-quick-select ? 0 : 400px;
        width: 100%;
        height: 100%;
        background: transparent;
        
        animate y {
            duration: 200ms;
            easing: ease-out;
        }
        
        // Semi-transparent backdrop (tap to dismiss)
        if root.show-quick-select : TouchArea {
            x: 0;
            y: 0;
            width: 100%;
            height: 100%;
            clicked => { root.show-quick-select = false; }
        }
        
        // Bottom Sheet Box
        Rectangle {
            y: parent.height - self.height;
            width: 100%;
            height: 190px;
            background: Theme.surface;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
            border-width: 1px;
            border-color: Theme.elevated;
            
            VerticalLayout {
                padding: Theme.padding-screen;
                spacing: Theme.gap-md;
                
                // Sheet Header
                HorizontalLayout {
                    alignment: space-between;
                    height: 24px;
                    Text {
                        text: "Quick Controls";
                        color: Theme.text-primary;
                        font-size: Theme.font-primary;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    IconButton {
                        text: "Done";
                        width: 48px;
                        height: 20px;
                        clicked => { root.show-quick-select = false; }
                    }
                }
                
                // Routing Mode quick toggle segmented buttons
                VerticalLayout {
                    spacing: 2px;
                    Text { text: "Routing Preset"; color: Theme.text-secondary; font-size: Theme.font-metadata; }
                    HorizontalLayout {
                        spacing: 4px;
                        height: 24px;
                        
                        Rectangle {
                            background: root.routing-preset == "Bypass LAN & China" ? Theme.accent : Theme.elevated;
                            border-radius: 4px;
                            TouchArea {
                                clicked => {
                                    root.routing-preset = "Bypass LAN & China";
                                    root.save-settings(root.core-type, root.socks-port, root.http-port, root.dns-server, root.routing-preset);
                                }
                                Text { text: "Bypass China"; color: #ffffff; font-size: Theme.font-metadata; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                        
                        Rectangle {
                           background: root.routing-preset == "Global" ? Theme.accent : Theme.elevated;
                           border-radius: 4px;
                           TouchArea {
                               clicked => {
                                   root.routing-preset = "Global";
                                   root.save-settings(root.core-type, root.socks-port, root.http-port, root.dns-server, root.routing-preset);
                               }
                               Text { text: "Global"; color: #ffffff; font-size: Theme.font-metadata; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                           }
                        }
                    }
                }
                
                // Active node indicator & Redirect button
                VerticalLayout {
                    spacing: Theme.gap-md;
                    alignment: center;
                    
                    Text {
                        text: "Active Node: " + root.active-profile;
                        color: Theme.text-secondary;
                        font-size: Theme.font-metadata;
                        overflow: elide;
                    }
                    
                    IconButton {
                        icon-source: Icons.nav-proxies;
                        text: "Select Nodes / Proxies";
                        background-color: Theme.elevated;
                        hover-background-color: Theme.elevated.brighter(10%);
                        active-background-color: Theme.surface;
                        height: 28px;
                        clicked => {
                            root.show-quick-select = false;
                            root.active-page-index = 1; // Go to Proxies tab
                        }
                    }
                }
            }
        }
    }

    // 4. Subscription Menu Options Bottom Sheet
    Rectangle {
        x: 0;
        y: root.show-sub-menu ? 0 : 400px;
        width: 100%;
        height: 100%;
        background: transparent;
        
        animate y {
            duration: 200ms;
            easing: ease-out;
        }
        
        // Semi-transparent backdrop (tap to dismiss)
        if root.show-sub-menu : TouchArea {
            x: 0;
            y: 0;
            width: 100%;
            height: 100%;
            clicked => { root.show-sub-menu = false; }
        }
        
        // Bottom Sheet Content
        Rectangle {
            y: parent.height - self.height;
            width: 100%;
            height: 130px;
            background: Theme.surface;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
            border-width: 1px;
            border-color: Theme.elevated;
            
            VerticalLayout {
                padding: Theme.padding-screen;
                spacing: Theme.gap-md;
                
                // Header: name + type badge
                HorizontalLayout {
                    alignment: space-between;
                    height: 20px;
                    Text {
                        text: root.selected-sub-name;
                        color: Theme.text-primary;
                        font-size: Theme.font-primary;
                        font-weight: 700;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                    // Type badge
                    Rectangle {
                        width: 72px;
                        height: 16px;
                        border-radius: 8px;
                        background: root.selected-sub-type == "LocalGroup" ? Theme.accent-purple.with-alpha(0.25) : Theme.accent-cyan.with-alpha(0.18);
                        Text {
                            text: root.selected-sub-type == "LocalGroup" ? "Local Group" : "Subscription";
                            color: root.selected-sub-type == "LocalGroup" ? Theme.accent-purple : Theme.accent-cyan;
                            font-size: 8px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                
                // Conditional Actions Row
                HorizontalLayout {
                    spacing: Theme.gap-md;
                    alignment: center;
                    
                    // --- SUBSCRIPTION actions ---
                    if root.selected-sub-type == "Subscription" : IconButton {
                        icon-source: Icons.fetch;
                        text: "Sync";
                        background-color: Theme.accent;
                        hover-background-color: Theme.accent.brighter(10%);
                        active-background-color: Theme.accent.darker(15%);
                        height: 28px;
                        clicked => {
                            root.show-sub-menu = false;
                            root.import-subscription(root.selected-sub-name, root.selected-sub-url);
                        }
                    }
                    if root.selected-sub-type == "Subscription" : IconButton {
                        icon-source: Icons.upload;
                        text: "Copy Link";
                        background-color: Theme.elevated;
                        hover-background-color: Theme.elevated.brighter(10%);
                        active-background-color: Theme.surface;
                        height: 28px;
                        clicked => {
                            root.show-sub-menu = false;
                            root.copy-text(root.selected-sub-url);
                        }
                    }

                    // --- LOCAL GROUP actions ---
                    if root.selected-sub-type == "LocalGroup" : IconButton {
                        icon-source: Icons.clipboard;
                        text: "Add Config";
                        background-color: Theme.accent-purple.with-alpha(0.35);
                        hover-background-color: Theme.accent-purple.with-alpha(0.5);
                        active-background-color: Theme.accent-purple.with-alpha(0.2);
                        height: 28px;
                        clicked => {
                            root.show-sub-menu = false;
                            root.add-config-to-group(root.selected-sub-id);
                        }
                    }
                    if root.selected-sub-type == "LocalGroup" : IconButton {
                        icon-source: Icons.fetch;
                        text: "Rename";
                        background-color: Theme.elevated;
                        hover-background-color: Theme.elevated.brighter(10%);
                        active-background-color: Theme.surface;
                        height: 28px;
                        clicked => {
                            // Rename to a placeholder — in a full implementation this would open an input.
                            root.show-sub-menu = false;
                            root.rename-profile(root.selected-sub-id, root.selected-sub-name + " (renamed)");
                        }
                    }

                    // --- SHARED: Delete (both types) ---
                    IconButton {
                        icon-source: Icons.delete;
                        text: "Delete";
                        background-color: Theme.danger;
                        hover-background-color: Theme.danger.brighter(10%);
                        active-background-color: Theme.danger.darker(15%);
                        height: 28px;
                        clicked => {
                            root.show-sub-menu = false;
                            root.delete-profile(root.selected-sub-id);
                        }
                    }
                }
            }
        }
    }
}
