export global Theme {
    // Color Palette Tokens
    in-out property <color> background: #171821;
    in-out property <color> surface: #21222d;
    in-out property <color> elevated: #2d3748;
    in-out property <color> accent: #3182ce;
    
    in-out property <color> text-primary: #ffffff;
    in-out property <color> text-secondary: #a0aec0;
    in-out property <color> text-muted: #718096;

    in-out property <color> success: #48bb78;
    in-out property <color> warning: #ecc94b;
    in-out property <color> danger: #e53e3e;
    
    // Spacing Scale Tokens (reduced by 30%-50%, using 4px/8px/12px increments)
    in-out property <length> padding-screen: 12px;
    in-out property <length> gap-md: 8px;
    in-out property <length> gap-lg: 12px;
    in-out property <length> nav-spacing: 8px;
    
    // Card Sizing Tokens
    in-out property <length> card-radius: 6px;
    in-out property <length> card-padding: 8px;

    // Strict Two-Tier Typography system
    in-out property <length> font-primary: 12px;
    in-out property <length> font-metadata: 9.5px;
    in-out property <length> font-header: 14px;
}
